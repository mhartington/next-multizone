{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "DOCS_ORIGIN",
        "BLOG_ORIGIN",
        "WEB_SITE_URL",
        "DOCS_SITE_URL",
        "BLOG_SITE_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
